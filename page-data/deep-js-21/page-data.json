b7c0d9e11b7","fields":{"slug":"/prototype-2/"},"frontmatter":{"title":"19. 프로토타입 (Prototype) (2)"}}},{"node":{"id":"e040841c-6725-5ae4-800d-77c1e2ff8d80","fields":{"slug":"/prototype-3/"},"frontmatter":{"title":"19. 프로토타입 (Prototype) (3)"}}},{"node":{"id":"1b6d17bd-8826-52c9-9827-d9e571c174d7","fields":{"slug":"/deep-js-20/"},"frontmatter":{"title":"20. strict mode"}}},{"node":{"id":"e076f928-82ca-5782-bd0b-d5a9f1193424","fields":{"slug":"/deep-js-21/"},"frontmatter":{"title":"21. 빌트인 객체 (Built in Object)"}}},{"node":{"id":"7838b24f-4b67-5b84-a0d1-1aafb1c2c363","fields":{"slug":"/deep-js-22/"},"frontmatter":{"title":"22. this"}}},{"node":{"id":"b7bdbe02-c25a-5449-a2b0-10c6c18a5e6d","fields":{"slug":"/deep-js-23/"},"frontmatter":{"title":"23. 실행컨텍스트"}}},{"node":{"id":"6451dd8c-7943-548d-8f88-16799914fc02","fields":{"slug":"/deep-js-24/"},"frontmatter":{"title":"24. 클로저"}}},{"node":{"id":"d5a056bb-3c94-5680-8d22-0256b8e9843e","fields":{"slug":"/deep-js-38/"},"frontmatter":{"title":"38. 브라우저의 렌더링 과정"}}}]},"previous":{"fields":{"slug":"/deep-js-20/"},"frontmatter":{"title":"20. strict mode"}},"next":{"fields":{"slug":"/deep-js-22/"},"frontmatter":{"title":"22. this"}}},"pageContext":{"id":"e076f928-82ca-5782-bd0b-d5a9f1193424","series":"모던 자바스크립트 Deep Dive","previousPostId":"1b6d17bd-8826-52c9-9827-d9e571c174d7","nextPostId":"7838b24f-4b67-5b84-a0d1-1aafb1c2c363"}},"staticQueryHashes":[],"slicesMap":{}}